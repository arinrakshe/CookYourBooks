# Copy this file to .env.local and fill in real values.
# Source it before running the backend:
#   set -a; source .env.local; set +a
#   mvn spring-boot:run

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Local dev:
#   DATABASE_URL=jdbc:postgresql://localhost:5432/cookyourbooks
# Supabase pooler (transaction or session mode):
#   DATABASE_URL=jdbc:postgresql://aws-1-<region>.pooler.supabase.com:5432/postgres
#   DATABASE_USERNAME=postgres.<project-ref>
DATABASE_URL=jdbc:postgresql://localhost:5432/cookyourbooks
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=replace-me

# ── JWT ───────────────────────────────────────────────────────────────────────
# Base64-encoded HMAC secret. Must decode to at least 32 bytes (256 bits).
# Generate with:  openssl rand -base64 32
JWT_SECRET=replace-with-output-of-openssl-rand-base64-32
JWT_TTL_MINUTES=120

# ── Web frontend / CORS ───────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the API from the browser.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# ── Google Gemini (recipe OCR import) ─────────────────────────────────────────
# Get a key at https://aistudio.google.com/apikey
# Leave blank to disable OCR import (the /api/ocr/import endpoint will 502).
GEMINI_API_KEY=

# ── USDA FoodData Central (nutrition lookups) ─────────────────────────────────
# https://api.data.gov/signup  — or use the shared DEMO_KEY (rate-limited).
USDA_API_KEY=DEMO_KEY
