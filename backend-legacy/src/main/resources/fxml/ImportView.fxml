<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ProgressBar?>

<VBox spacing="12"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="app.cookyourbooks.gui.controller.ImportController">
    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>

    <Label text="Import Recipe" />

    <HBox spacing="12" alignment="CENTER_LEFT">
    <Button fx:id="startButton" text="Choose Image" onAction="#handleStartImport" accessibleText="Choose Image: Select a recipe image to import"/>
    <Button fx:id="cancelButton" text="Cancel" onAction="#handleCancel" accessibleText="Cancel: Cancel the current import process"/>
    <Label text="State:"/>
    <Label fx:id="stateLabel" accessibleText="Current import state"/>
    </HBox>

    <Label text="Import Progress" />
    <HBox spacing="8" alignment="CENTER_LEFT">
        <ProgressBar fx:id="progressBar" prefWidth="320" progress="0.0" styleClass="import-progress-bar" />
        <Label fx:id="progressLabel" text="0%" style="-fx-font-size: 11; -fx-text-fill: #7f8c8d;" />
    </HBox>

    <Label text="Recipe Title" />
    <TextField fx:id="titleField" promptText="Imported recipe title" accessibleText="Recipe title: Edit the imported recipe title. Press Tab to navigate to ingredients." />

    <Label text="Ingredients" />
    <ListView fx:id="ingredientsListView" editable="true" prefHeight="220" accessibleText="Ingredients list: Press Up/Down arrows to navigate, Enter to edit, Delete to remove, Escape to cancel edit." />

    <Button fx:id="addIngredientButton" text="Add Ingredient" onAction="#handleAddIngredient" accessibleText="Add Ingredient: Add a new ingredient to the list"/>

    <Label text="Target Collection" />
    <ComboBox fx:id="collectionComboBox" prefWidth="300" accessibleText="Target Collection: Select which recipe collection to save this import into. Use arrow keys to navigate options." />

    <HBox spacing="8">
        <Button fx:id="acceptButton" text="Accept Import" onAction="#handleAccept" accessibleText="Accept Import: Save this recipe to the selected collection"/>
        <Button fx:id="rejectButton" text="Reject" onAction="#handleReject" accessibleText="Reject: Discard this imported recipe"/>
    </HBox>

    <Label fx:id="statusLabel" text="Ready" />
    <Label fx:id="errorLabel" />
</VBox>